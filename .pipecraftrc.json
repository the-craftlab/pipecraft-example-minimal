{
  "ciProvider": "github",
  "mergeStrategy": "fast-forward",
  "requireConventionalCommits": true,
  "initialBranch": "develop",
  "finalBranch": "main",
  "branchFlow": ["develop", "main"],
  "autoPromote": { "main": true },
  "semver": {
    "bumpRules": { "feat": "minor", "fix": "patch", "breaking": "major" }
  },
  "domains": {
    "app": {
      "paths": ["src/**"],
      "description": "Application code",
      "prefixes": ["test"]
    }
  }
}
